# Connection string do PostgreSQL (deve apontar para o banco do docker-compose)
DATABASE_URL=postgresql+asyncpg://aiops:aiops123@localhost:5432/aiops_k8s

# Requesty gateway (recommended for production)
ANTHROPIC_API_KEY=rqsty-sk-...
ANTHROPIC_BASE_URL=https://router.requesty.ai
AGENT_MODEL_NAME=anthropic/claude-sonnet-4-5

# Endpoint HTTP do MCP Server Kubernetes (executado localmente via npx, transport streamable HTTP)
MCP_SERVER_URL=http://localhost:3001/mcp

# Optional shared secret when MCP_AUTH_TOKEN is enabled on the MCP server
MCP_AUTH_TOKEN=

# Basic Auth for the web UI (leave BASIC_AUTH_PASSWORD empty to disable auth)
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=

# GitOps fixes — PAT with Contents + Pull requests write on guiadodevops
# (GitHub Actions secret must be named GITOPS_GITHUB_TOKEN — GITHUB_ prefix is reserved)
GITHUB_TOKEN=
GITOPS_REPO=flaviorssilva1981/guiadodevops
GITOPS_WORK_BRANCH=dev
GITOPS_DEPLOY_BRANCH=main
GITOPS_AUTO_MERGE=false
